# ─── CryptoX Production Environment Variables ─────────────────────────────
# Copy to .env.production and fill in all values before deploying.
# NEVER commit .env.production to version control.

# ── Core ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=8080
BASE_PATH=/api/

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://cryptox:STRONG_PASSWORD@db-host:5432/cryptox_prod?sslmode=require

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis-host:6379
# If Redis requires a password:
# REDIS_URL=redis://:PASSWORD@redis-host:6379

# ── Session / JWT ────────────────────────────────────────────────────────────
SESSION_SECRET=CHANGE_ME_VERY_LONG_RANDOM_STRING_AT_LEAST_64_CHARS
JWT_SECRET=ANOTHER_LONG_RANDOM_STRING_FOR_HMAC_JWT_SIGNING

# ── CORS & Domain ────────────────────────────────────────────────────────────
ALLOWED_ORIGIN=https://yourdomain.com
API_BASE_URL=https://yourdomain.com

# ── Go Service ───────────────────────────────────────────────────────────────
GO_SERVICE_URL=http://127.0.0.1:8090
GO_SERVICE_BIND=127.0.0.1

# ── Razorpay (Payment Gateway) ────────────────────────────────────────────────
# Configure via Admin → Payment Gateways (stored encrypted in DB)
# RAZORPAY_KEY_ID=rzp_live_XXXXX
# RAZORPAY_KEY_SECRET=XXXXX
# RAZORPAY_WEBHOOK_SECRET=XXXXX

# ── Email (SMTP / SendGrid / Mailgun / Postmark) ──────────────────────────────
# Configure via Admin → API Integrations → Email API (stored in DB)
# SMTP example:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=noreply@yourdomain.com
# SMTP_PASS=app-specific-password
# SMTP_FROM=CryptoX <noreply@yourdomain.com>

# ── SMS OTP (MSG91 / Twilio / Fast2SMS / 2Factor) ────────────────────────────
# Configure via Admin → OTP Providers (stored in DB)
# MSG91_AUTH_KEY=XXXXX
# MSG91_TEMPLATE_ID=XXXXX
# TWILIO_ACCOUNT_SID=XXXXX
# TWILIO_AUTH_TOKEN=XXXXX
# TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# ── Push Notifications (FCM) ─────────────────────────────────────────────────
# Configure via Admin → Settings → push.fcmKey (stored in DB)
# FCM_SERVER_KEY=AAAA...

# ── Crypto / HD Wallet ────────────────────────────────────────────────────────
# Configure via Admin → HD Wallet (stored encrypted in DB vault)
# VAULT_PASSWORD=STRONG_VAULT_PASSWORD_FOR_MNEMONIC_ENCRYPTION

# ── OpenAI (for AI features) ─────────────────────────────────────────────────
# Configure via Replit Integrations or set directly:
# OPENAI_API_KEY=sk-...

# ── Monitoring / Observability ────────────────────────────────────────────────
LOG_LEVEL=info
# Sentry DSN (optional):
# SENTRY_DSN=https://xxx@sentry.io/xxx

# ── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── TDS (India Tax Deducted at Source) ───────────────────────────────────────
# Configured via Admin → Settings → tds.percent (default: 1)
# This is automatically applied on all sell orders.

# ── Indian Regulatory Compliance ─────────────────────────────────────────────
# PAN verification API (optional, for advanced KYC):
# PAN_VERIFY_API_KEY=XXXXX
# PAN_VERIFY_URL=https://api.yourkyc.com/pan/verify

# ── Deployment ───────────────────────────────────────────────────────────────
# PM2 cluster instances (set to number of CPU cores):
API_INSTANCES=4
