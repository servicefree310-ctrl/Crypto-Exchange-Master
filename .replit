modules = ["nodejs-24", "go-1.21", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "vm"
run = ["bash", "start-prod.sh"]
build = ["bash", "build-prod.sh"]

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "artifacts/crypto-exchange-flutter: web"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Go Service"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "User Portal"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Admin Panel"

[[workflows.workflow]]
name = "artifacts/crypto-exchange-flutter: web"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash -c 'PORT=8082 BASE_PATH=/flutter/ bash artifacts/crypto-exchange-flutter/scripts/dev.sh'"
waitForPort = 8082

[[workflows.workflow]]
name = "Go Service"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash -c 'cd artifacts/go-service && PORT=23004 BASE_PATH=/go-service/ BIND_ADDR=127.0.0.1 ./bin/cryptox-go'"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "API Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash -c 'cd artifacts/api-server && PORT=8080 BASE_PATH=/api/ NODE_ENV=development node --enable-source-maps ./dist/index.mjs'"
waitForPort = 8080

[[workflows.workflow]]
name = "User Portal"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash -c 'cd artifacts/user-portal && PORT=5000 BASE_PATH=/user/ NODE_ENV=development pnpm run dev'"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Admin Panel"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash -c 'cd artifacts/admin && PORT=3000 BASE_PATH=/admin/ NODE_ENV=development pnpm run dev'"
waitForPort = 3000

[workflows.workflow.metadata]
outputType = "console"

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true
integrations = ["javascript_openai_ai_integrations:2.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8082
externalPort = 5000

[[ports]]
localPort = 8083
externalPort = 6000

[[ports]]
localPort = 8084
externalPort = 6800

[[ports]]
localPort = 8085
externalPort = 8008

[[ports]]
localPort = 8086
externalPort = 9000

[[ports]]
localPort = 23004
externalPort = 8099
exposeLocalhost = true

[[ports]]
localPort = 23475
externalPort = 8081

[[ports]]
localPort = 23744
externalPort = 3001

[[ports]]
localPort = 23745
externalPort = 4200

[[ports]]
localPort = 23746
externalPort = 5173

[[ports]]
localPort = 23747
externalPort = 3003

[[ports]]
localPort = 23748
externalPort = 8000

[[ports]]
localPort = 24725
externalPort = 3000

[[ports]]
localPort = 24726
externalPort = 3002

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
NODE_ENV = "development"
PORT = "8081"
BASE_PATH = "/api/"
GO_SERVICE_URL = "http://127.0.0.1:23004"
LOG_LEVEL = "info"
LEADER_SINGLE_INSTANCE_FALLBACK = "true"
REDIS_SERVER_BIN = "/nix/store/mx6ib31vd9m6rcabnv9h27zx7kqibkng-redis-7.2.4/bin/redis-server"

[userenv.production]
CORS_ORIGINS = "https://workspace.servicefree310.replit.app"
